# NICHE SOCIAL MEDIA APP - CLIENT ENVIRONMENT VARIABLES
# Copy this file to .env and fill in actual values
# NEVER commit .env to git (it's in .gitignore)

# ==================== API BASE URL ====================
# This is where the backend API is hosted
# Development: http://localhost:5000
# Production: https://your-api-domain.com (must include https for production)
# Must NOT have trailing slash
VITE_API_BASE=http://localhost:5000

# ==================== DEPLOYMENT NOTES ====================
# For production:
# 1. Change VITE_API_BASE to your production backend URL
# 2. Ensure backend API is deployed and accessible
# 3. Run: npm run build
# 4. Deploy dist/ folder to static hosting (Vercel, Netlify, etc.)
# 5. Verify OAuth flow works with production Google credentials
