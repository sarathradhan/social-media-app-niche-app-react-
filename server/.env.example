# NICHE SOCIAL MEDIA APP - SERVER ENVIRONMENT VARIABLES
# Copy this file to .env and fill in actual values
# NEVER commit .env to git (it's in .gitignore)

# ==================== NODE ENVIRONMENT ====================
NODE_ENV=development
PORT=5000

# ==================== DATABASE ====================
# Option 1: Use individual DB variables (recommended for security)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-secure-password-here
DB_NAME=website

# Option 2: Use DATABASE_URL (comment out if using individual variables)
# DATABASE_URL=postgresql://user:password@localhost:5432/website

# For production, use a managed database service:
# - AWS RDS PostgreSQL
# - Azure Database for PostgreSQL
# - Railway PostgreSQL
# - Supabase (PostgreSQL + Auth)
# - Google Cloud SQL

# ==================== SESSION SECURITY ====================
# Generate a strong secret with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate-a-random-string-here-min-32-chars

# ==================== GOOGLE OAUTH 2.0 ====================
# Get these from Google Cloud Console:
# 1. Go to https://console.cloud.google.com
# 2. Create a new project or select existing
# 3. Enable Google+ API
# 4. Go to Credentials > Create OAuth 2.0 Client ID
# 5. Select "Web application"
# 6. Add authorized redirect URIs:
#    - Development: http://localhost:5000/api/auth/google/callback
#    - Production: https://your-domain.com/api/auth/google/callback
# 7. Copy Client ID and Client Secret below

GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Format: http://localhost:5000/api/auth/google/callback (dev)
#         https://your-domain.com/api/auth/google/callback (production)
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ==================== FRONTEND CONFIGURATION ====================
# The URL where your React frontend is deployed
# Development: http://localhost:5173 (Vite default)
# Production: https://your-frontend-domain.com
CLIENT_ORIGIN=http://localhost:5173

# ==================== DEPLOYMENT NOTES ====================
# For production deployment:
# 1. Generate strong SESSION_SECRET
# 2. Update GOOGLE_CALLBACK_URL to production domain
# 3. Update CLIENT_ORIGIN to production domain
# 4. Use managed PostgreSQL database (don't use local)
# 5. Set NODE_ENV=production
# 6. Enable HTTPS for both frontend and backend
# 7. Update Google Cloud Console with production URLs
# 8. Never commit this file to git
